 <!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zeta Sabor - Versión Final</title>
    <style>
        :root { 
            --blue: #00d4ff; --green: #2ecc71; --orange: #f39c12; --red: #ff4d4d; 
            --bg: #05070a; --card: rgba(22, 27, 34, 0.95);
        }
        
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: #fff; margin: 0; padding: 15px; }
        .container { max-width: 500px; margin: auto; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        h1 { text-align: center; color: var(--blue); text-shadow: 0 0 15px var(--blue); font-size: 1.8rem; }
        .section { background: var(--card); padding: 20px; border-radius: 25px; margin-bottom: 20px; border: 1px solid rgba(0, 212, 255, 0.2); box-shadow: 0 10px 30px rgba(0,0,0,0.6); }
        h3 { margin: 0 0 15px 0; color: var(--blue); font-size: 0.9rem; text-transform: uppercase; }

        input, select { width: 100%; padding: 12px; margin: 8px 0; border-radius: 12px; border: 1px solid #333; background: #000; color: #fff; font-size: 14px; box-sizing: border-box; }
        
        .btn { padding: 14px; border: none; border-radius: 15px; font-weight: bold; cursor: pointer; transition: 0.3s; width: 100%; text-transform: uppercase; }
        .btn-blue { background: linear-gradient(45deg, var(--blue), #005f73); color: #fff; margin-top: 5px; }
        .btn-green { background: linear-gradient(45deg, var(--green), #1b4d3e); color: #fff; margin-top: 10px; }
        
        .status-btn { padding: 6px 10px; border-radius: 10px; font-size: 10px; font-weight: bold; border: none; cursor: pointer; }
        .st-pendiente { background: #444; color: white; }
        .st-friendo { background: var(--orange); color: #000; animation: blink 1s infinite; }
        .st-pagado { background: var(--green); color: #000; }
        @keyframes blink { 50% { opacity: 0.5; } }

        .row-item { background: rgba(255,255,255,0.05); padding: 12px; border-radius: 15px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(255,255,255,0.1); }
        .stock-badge { background: var(--blue); color: #000; padding: 2px 6px; border-radius: 6px; font-size: 11px; font-weight: bold; margin-left: 10px; }
        .del-btn { background: none; border: none; color: var(--red); font-size: 1.3rem; cursor: pointer; }
        .edit-btn { background: none; border: none; color: var(--orange); font-size: 1.1rem; cursor: pointer; margin-right: 10px; }

        .hist-card { background: rgba(255,255,255,0.03); border-left: 4px solid var(--blue); padding: 15px; border-radius: 20px; margin-top: 15px; position: relative; }
        .method-label { background: rgba(255,255,255,0.1); color: #ddd; padding: 4px 8px; border-radius: 8px; font-size: 11px; display: inline-block; margin-top: 5px; border: 1px solid #444; }
    </style>
</head>
<body>

<div class="container">
    <h1>ZETA SABOR ELITE ⚡</h1>

    <div class="section">
        <h3>📦 CONFIGURAR MENÚ</h3>
        <input type="text" id="m-name" placeholder="Producto (Ej: Pastelito)">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <input type="number" id="m-usd" placeholder="Precio $">
            <input type="number" id="m-bs" placeholder="Precio Bs">
        </div>
        <input type="number" id="m-stock" placeholder="Stock Inicial">
        <button class="btn btn-blue" onclick="addMenu()">+ GUARDAR PRODUCTO</button>
        <div id="menu-list" style="margin-top:15px;"></div>
    </div>

    <div class="section">
        <h3>💰 REGISTRAR PEDIDO</h3>
        <input type="text" id="c-name" placeholder="Nombre del Cliente">
        <select id="sel-prod"></select>
        <input type="number" id="s-qty" placeholder="Cantidad">
        <button class="btn btn-blue" onclick="toCart()">+ AÑADIR AL PEDIDO</button>
        <div id="cart" style="margin: 15px 0;"></div>
        <div style="text-align: right; margin-bottom: 10px;">
            <div id="t-usd" style="color:var(--green); font-size: 1.4rem; font-weight: bold;">Total: $0.00</div>
            <div id="t-bs" style="color:var(--blue); font-size: 1.1rem;">0.00 Bs</div>
        </div>
        <input type="text" id="p-method" placeholder="¿Cómo pagó? (Ej: Pago Móvil)">
        <button class="btn btn-green" onclick="finishSale()">CONFIRMAR VENTA ✅</button>
    </div>

    <div class="section">
        <h3>📋 MOVIMIENTOS</h3>
        <div id="hist"></div>
    </div>
</div>

<script>
    let menu = JSON.parse(localStorage.getItem('zs_final_v4')) || [];
    let sales = JSON.parse(localStorage.getItem('zs_sales_v4')) || [];
    let cart = [];

    function addMenu() {
        const name = document.getElementById('m-name').value;
        const pUSD = parseFloat(document.getElementById('m-usd').value) || 0;
        const pBS = parseFloat(document.getElementById('m-bs').value) || 0;
        const stock = parseInt(document.getElementById('m-stock').value) || 0;
        if(name) {
            menu.push({ name, pUSD, pBS, stock });
            save();
            document.getElementById('m-name').value = ''; document.getElementById('m-usd').value = ''; 
            document.getElementById('m-bs').value = ''; document.getElementById('m-stock').value = '';
        }
    }

    function toCart() {
        const idx = document.getElementById('sel-prod').value;
        const qty = parseInt(document.getElementById('s-qty').value);
        if(!menu[idx] || !qty) return;
        if(menu[idx].stock >= qty) {
            cart.push({ ...menu[idx], qty, originalIdx: idx });
            menu[idx].stock -= qty;
            render();
            document.getElementById('s-qty').value = '';
        } else { alert("Stock insuficiente."); }
    }

    function removeFromCart(index) {
        const item = cart[index];
        menu[item.originalIdx].stock += item.qty;
        cart.splice(index, 1);
        render();
    }

    function finishSale() {
        if(cart.length === 0) return;
        const totals = calculateTotals();
        const now = new Date();
        sales.push({
            id: Date.now(),
            client: document.getElementById('c-name').value || "Cliente",
            items: cart.map(i => ({ name: i.name, qty: i.qty, pUSD: i.pUSD, pBS: i.pBS })),
            totalUSD: totals.usd, totalBS: totals.bs,
            method: document.getElementById('p-method').value || "Efectivo",
            status: 'pendiente',
            time: now.toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit', hour12: true }),
            date: now.toLocaleDateString('es-VE', { day: '2-digit', month: 'short' })
        });
        cart = []; document.getElementById('c-name').value = ''; document.getElementById('p-method').value = '';
        save();
    }

    function calculateTotals() {
        let u = 0; let b = 0;
        cart.forEach(i => { u += (i.pUSD * i.qty); b += (i.pBS * i.qty); });
        return { usd: u.toFixed(2), bs: b.toFixed(2) };
    }

    function changeStatus(id) {
        const s = sales.find(x => x.id === id);
        const steps = { 'pendiente': 'friendo', 'friendo': 'pagado', 'pagado': 'pendiente' };
        s.status = steps[s.status];
        save();
    }

    function editSale(id) {
        const s = sales.find(x => x.id === id);
        document.getElementById('c-name').value = s.client;
        document.getElementById('p-method').value = s.method;
        s.items.forEach(item => {
            const mIdx = menu.findIndex(m => m.name === item.name);
            if(mIdx !== -1) cart.push({ ...item, originalIdx: mIdx });
        });
        sales = sales.filter(x => x.id !== id);
        save();
    }

    function deleteSale(id) {
        if(confirm("¿Eliminar venta?")) { sales = sales.filter(x => x.id !== id); save(); }
    }

    function save() {
        localStorage.setItem('zs_final_v4', JSON.stringify(menu));
        localStorage.setItem('zs_sales_v4', JSON.stringify(sales));
        render();
    }

    function render() {
        const ml = document.getElementById('menu-list');
        const sel = document.getElementById('sel-prod');
        ml.innerHTML = ''; sel.innerHTML = '';
        menu.forEach((item, i) => {
            ml.innerHTML += `<div class="row-item"><span><b>${item.name}</b> <br><small>$${item.pUSD}/${item.pBS}Bs</small><span class="stock-badge">STOCK: ${item.stock}</span></span><button class="del-btn" onclick="menu.splice(${i},1);save()">×</button></div>`;
            sel.innerHTML += `<option value="${i}">${item.name} (${item.stock} disp.)</option>`;
        });

        document.getElementById('cart').innerHTML = cart.map((i, idx) => `<div class="row-item" style="border-left: 3px solid var(--blue);"><span>${i.qty}x ${i.name}</span><button class="del-btn" onclick="removeFromCart(${idx})">×</button></div>`).join('');
        
        const t = calculateTotals();
        document.getElementById('t-usd').innerText = `Total: $${t.usd}`;
        document.getElementById('t-bs').innerText = `${t.bs} Bs`;

        document.getElementById('hist').innerHTML = sales.slice().reverse().map(s => `
            <div class="hist-card">
                <div style="display:flex; justify-content:space-between;">
                    <small style="color:#666">${s.date} | ${s.time}</small>
                    <button class="status-btn st-${s.status}" onclick="changeStatus(${s.id})">${s.status.toUpperCase()}</button>
                </div>
                <div style="margin:10px 0;">
                    <b>${s.client}</b>: ${s.items.map(i => i.qty + " " + i.name).join(", ")}<br>
                    <span style="color:var(--green); font-weight:bold;">$${s.totalUSD} / ${s.totalBS}Bs</span><br>
                    <div class="method-label">PAGO: ${s.method}</div>
                </div>
                <div style="display:flex; justify-content:flex-end; gap:12px;">
                    <button class="edit-btn" onclick="editSale(${s.id})">✏️ EDITAR</button>
                    <button class="del-btn" onclick="deleteSale(${s.id})">🗑️</button>
                </div>
            </div>`).join('');
    }
    render();
</script>
</body>
</html>
